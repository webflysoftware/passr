NODE_ENV=production
PORT=3010
HOST=127.0.0.1

# Dedicated Passr database (separate from other apps on the same MongoDB instance)
MONGODB_URI=mongodb://127.0.0.1:27017/passr

# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-in-production

# Comma-separated emails that receive super-admin privileges
PASSR_SUPER_ADMIN_EMAILS=you@example.com

# Emails on these domains are also treated as super-admins
PASSR_SUPER_ADMIN_DOMAINS=passr.net,webfly.io

# Optional: auto-verify new accounts (set false in production when email is wired up)
AUTO_VERIFY_EMAIL=true

# Public site URL (used in password reset links)
SITE_URL=https://passr.net

# Password reset link expiry in minutes
PASSWORD_RESET_MINUTES=60

# Email verification link expiry in minutes (default 24 hours)
EMAIL_VERIFICATION_MINUTES=1440

# Postmark (preferred — used when POSTMARK_API_TOKEN is set)
POSTMARK_API_TOKEN=
POSTMARK_FROM=PASSR <hello@passr.net>
# POSTMARK_MESSAGE_STREAM=outbound

# SMTP fallback (optional — emails are logged to console when neither Postmark nor SMTP is set)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=PASSR <noreply@passr.net>
